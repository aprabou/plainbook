{
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install . && pip install pandas matplotlib",
  "postStartCommand": "bash .devcontainer/start.sh",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Plainbook",
      "onAutoForward": "notify"
    }
  }
}
